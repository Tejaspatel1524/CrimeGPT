# Backend Environment Variables
# Copy this file to .env and update the values for your environment

# Database Connection
# Local Development: postgresql://postgres:password@localhost:5432/crimegpt
# Neon (Production): postgresql://user:password@ep-xxxxx.region.aws.neon.tech/crimegpt?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/crimegpt

# JWT Secret Key (CHANGE IN PRODUCTION - use a strong random string)
SECRET_KEY=crimegpt-secret-key-change-in-production

# AI Provider Configuration
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# CORS Configuration
# Development: http://localhost:5173
# Production: https://your-frontend-url.vercel.app
# Multiple origins: https://app1.com,https://app2.com
ALLOWED_ORIGINS=http://localhost:5173

# Optional: File Upload Configuration
# UPLOAD_BASE_DIR=uploads

# Optional: Session Configuration
# ACCESS_TOKEN_EXPIRE_MINUTES=30
